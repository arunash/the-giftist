<script>
function syncDyid() {
  const dyid = localStorage.getItem('_dyid');
  if (!dyid) return;

  const existingCookie = getCookie('_dyid_server');
  // No need to skip, we need to update expiration so its always 1 year from now
  // if (dyid === existingCookie) return;

  // Always set the cookie so the pixel can read it regardless of consent
  setOnEtldPlus1('_dyid_server', dyid, ONE_YEAR);

  // Also persist via Shopify metafield (best-effort, may fail without consent)
  try {
    if (window.Shopify?.customerPrivacy) {
      const existing = Shopify.customerPrivacy.getTrackingConsentMetafield('_dyid_server');
      if (dyid !== existing) {
        Shopify.customerPrivacy.setTrackingConsent({
          metafields: [{ key: '_dyid_server', value: dyid }]
        });
      }
    }
  } catch (_) {}
}

function syncDyjsession() {
  const existingCookie = getCookie('_dy_app_jsession');

  const setSessionCookie = () => {
    if (DY.jsession && !existingCookie) {
      Shopify.customerPrivacy.setTrackingConsent({
        metafields: [{ key: '_dy_app_jsession', value: DY.jsession }]
      });

      setOnEtldPlus1('_dy_app_jsession', DY.jsession);
      clearInterval(timer);
      return;
    }
    if (counter > 10) {
      clearInterval(timer);
      return;
    }
    counter++;
  };
  
  let counter = 0;
  const timer = setInterval(setSessionCookie, 1000);
  setSessionCookie();
}

/* Wait for DY to create _dyid and jsession */
let attempts = 0;
let jsessionSynced = false;
const wait = setInterval(() => {
  attempts++;
  const hasDyid = localStorage.getItem('_dyid');
  const hasJsession = window.DY?.jsession;
  
  if (hasDyid) syncDyid();
  if (hasJsession && !jsessionSynced) {
    syncDyjsession();
    jsessionSynced = true;
  }
  
  if ((hasDyid && jsessionSynced) || attempts > 20) {
    clearInterval(wait);
  }
}, 500);

/* Cross-tab support */
window.addEventListener('storage', e => {
  if (e.key === '_dyid') syncDyid();
});
</script>


  
